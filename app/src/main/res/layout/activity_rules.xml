<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@color/bg_color">

    <LinearLayout
        android:id="@+id/main"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp"
        android:gravity="center_horizontal">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Правила игры"
            android:textSize="32sp"
            android:textStyle="bold"
            android:textColor="#333333"
            android:layout_marginBottom="24dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="1️⃣ Выберите уровень сложности и типы задач на главном экране.\n\n2️⃣ Вам будет предложено решить 20 задач.\n\n3️⃣ У вас есть 3 попытки. За каждый неверный ответ отнимается одна жизнь.\n\n4️⃣ Введите ответ в поле и нажмите «Проверить».\n\n5️⃣ При успешном решении нажмите «Дальше» для перехода к следующей задаче.\n\n6️⃣ Если жизни закончатся или вы решите все 20 задач, раунд завершится."
            android:textSize="18sp"
            android:textColor="#555555"
            android:lineSpacingExtra="8dp"
            android:layout_marginBottom="32dp"/>

        <Button
            android:id="@+id/btnBackRules"
            android:layout_width="200dp"
            android:layout_height="60dp"
            android:text="Назад"
            android:textSize="20sp"
            android:background="@drawable/bg_neu_button"
            android:textColor="#FFFFFF"
            android:stateListAnimator="@null"
            android:padding="6dp"/>
    </LinearLayout>
</ScrollView>